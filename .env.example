# SpyderNetwork Environment Variables
# Copy this to .env.local and fill in values

# Your production domain (used for Twitch embed parent param)
NEXT_PUBLIC_SITE_DOMAIN=spydernetwork.com

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Future water temp API key (e.g. NOAA, Weather Underground)
# WATER_TEMP_API_KEY=
